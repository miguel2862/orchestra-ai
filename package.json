{
  "name": "orchestra-ai-app",
  "version": "0.1.3",
  "description": "AI-powered multi-agent project orchestrator with web UI. One command to build anything.",
  "type": "module",
  "bin": {
    "orchestra-ai": "dist/cli/index.mjs"
  },
  "files": [
    "dist/",
    "dist-ui/",
    "templates/"
  ],
  "scripts": {
    "build:server": "tsup",
    "build:ui": "vite build",
    "build": "npm run build:server && npm run build:ui",
    "dev:server": "tsup --watch",
    "dev:ui": "vite",
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:ui\"",
    "start": "node dist/cli/index.mjs",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "ai",
    "agent",
    "orchestrator",
    "claude",
    "anthropic",
    "coding-agent",
    "automation",
    "multi-agent",
    "code-generation",
    "llm",
    "developer-tools"
  ],
  "license": "MIT",
  "author": "miguel2862",
  "homepage": "https://github.com/miguel2862/orchestra-ai#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/miguel2862/orchestra-ai.git"
  },
  "bugs": {
    "url": "https://github.com/miguel2862/orchestra-ai/issues"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.37",
    "@inquirer/prompts": "^7.0.0",
    "chalk": "^5.3.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "open": "^10.1.0",
    "ora": "^8.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/react-query": "^5.60.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.5.12",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "lucide-react": "^0.460.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "tailwindcss": "^4.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
